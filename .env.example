# BYOK AI Tutoring Whiteboard — configuration
# API keys are NOT configured here: enter them in the app's BYOK settings UI,
# and they are forwarded to the backend as request headers per request.

# Frontend — URL of the Python backend (defaults to http://localhost:8000 if not set)
VITE_API_URL=http://localhost:8000

# Backend — comma-separated list of allowed CORS origins (defaults to Vite dev server)
ALLOWED_ORIGINS=http://localhost:7072,http://127.0.0.1:7072

# Backend — request limits (defaults shown)
#MAX_MESSAGES=200
#MAX_REQUEST_CHARS=25165824
#RATE_LIMIT_REQUESTS=30
#RATE_LIMIT_WINDOW_SECONDS=60
#MAX_COMPLETION_TOKENS=8192
